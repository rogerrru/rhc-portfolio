{
  "name": "rhc-portfolio-monorepo",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix server\" \"npm run dev --prefix client\"",
    "build": "npm run build --prefix client",
    "start": "npm run start --prefix server",
    "install:all": "npm install && npm install --prefix client && npm install --prefix server",
    "db:migrate": "npm run migrate --prefix server",
    "db:migrate:dev": "npm run migrate:dev --prefix server",
    "db:seed": "npm run seed --prefix server",
    "db:studio": "npm run studio --prefix server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
